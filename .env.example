# ── Public site URL (used in OG images, sitemap, llms.txt, email links) ──
NEXT_PUBLIC_SITE_URL=https://leorealtycapitalinvestments.com

# ── Database (Neon Postgres) ──
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ── Admin auth (NextAuth) ──
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── MLS (Bridge Data Output) ──
MLS_PROVIDER=bridge
MLS_API_BASE=https://api.bridgedataoutput.com/api/v2/OData
MLS_DATASET=test
MLS_SERVER_TOKEN=
MLS_BROWSER_TOKEN=
MLS_CLIENT_ID=
MLS_CLIENT_SECRET=

# ── Lead notifications (Brevo transactional) ──
# Required for the team to be alerted when a contact form is submitted.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@leorealtycapitalinvestments.com
BREVO_SENDER_NAME=Leo Realty Capital Investments
# Comma-separated list of recipients for new-lead alerts.
LEAD_NOTIFY_EMAIL=Info@leorealtycapitalinvestments.com
